@page "/workflow-viewer"
@rendermode InteractiveServer
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Workflow Viewer</PageTitle>

<div class="wf-page">
    <div class="wf-header">
        <div>
            <h3>Workflow Viewer</h3>
            <p class="wf-subtitle">
                Carregue um arquivo JSON do Elsa para visualizar atividades, elementos e conexões.
            </p>
        </div>
    </div>

    <div class="wf-toolbar">
        <InputFile OnChange="LoadWorkflowFile" accept=".json,application/json" class="form-control" />
    </div>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="wf-alert @(HasError ? "wf-alert-error" : "wf-alert-success")">
            @StatusMessage
        </div>
    }

    @if (Workflow is not null)
    {
        <div class="wf-summary-grid">
            <div class="wf-summary-card">
                <div class="wf-summary-label">Nome</div>
                <div class="wf-summary-value">@DisplayOrDash(Workflow.Name)</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">DefinitionId</div>
                <div class="wf-summary-value">@DisplayOrDash(Workflow.DefinitionId)</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">Id</div>
                <div class="wf-summary-value">@DisplayOrDash(Workflow.WorkflowId)</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">Tipo raiz</div>
                <div class="wf-summary-value">@DisplayOrDash(Workflow.RootType)</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">Atividades</div>
                <div class="wf-summary-value">@Workflow.Activities.Count</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">Conexões</div>
                <div class="wf-summary-value">@Workflow.Connections.Count</div>
            </div>
        </div>

        <div class="wf-section">
            <div class="wf-section-title">Container raiz</div>

            <div class="wf-root-card">
                <div class="wf-root-type">@DisplayOrDash(Workflow.RootType)</div>
                <div class="wf-root-name">@DisplayOrDash(Workflow.RootDisplayName)</div>
                <div class="wf-root-id">ID: @DisplayOrDash(Workflow.RootId)</div>
            </div>
        </div>

        @if (Workflow.Elements.Any())
        {
            <div class="wf-section">
                <div class="wf-section-title">Elementos do workflow</div>

                @foreach (var group in Workflow.Elements.GroupBy(x => x.Category))
                {
                    <div class="wf-element-group">
                        <div class="wf-element-group-title">@group.Key</div>

                        <div class="wf-element-grid">
                            @foreach (var item in group)
                            {
                                <div class="wf-element-card">
                                    <div class="wf-element-name">@DisplayOrDash(item.Name)</div>
                                    @if (!string.IsNullOrWhiteSpace(item.Type))
                                    {
                                        <div class="wf-element-type">@item.Type</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.Value))
                                    {
                                        <div class="wf-element-value">@item.Value</div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }

        <div class="wf-section">
            <div class="wf-section-title">Fluxo visual das atividades</div>
            <div class="wf-flow-note">
                A lista abaixo mostra as atividades encontradas no JSON. Em workflows com branches, o bloco de conexões logo abaixo é o que melhor representa o fluxo entre elas.
            </div>

            @if (!Workflow.Activities.Any())
            {
                <div class="wf-empty">
                    Nenhuma atividade foi encontrada dentro do JSON.
                </div>
            }
            else
            {
                <div class="wf-flow-list">
                    @for (var i = 0; i < Workflow.Activities.Count; i++)
                    {
                        var activity = Workflow.Activities[i];

                        <div class="wf-flow-item">
                            @if (i > 0)
                            {
                                <div class="wf-arrow">↓</div>
                            }

                            <div class="wf-node @GetNodeCssClass(activity)">
                                <div class="wf-node-top">
                                    <div>
                                        <div class="wf-node-title">@activity.DisplayName</div>
                                        <div class="wf-node-type">@activity.ShortType</div>
                                    </div>
                                    <div class="wf-node-badges">
                                        <span class="wf-badge">ID: @activity.Id</span>
                                        @if (!string.IsNullOrWhiteSpace(activity.SourceProperty))
                                        {
                                            <span class="wf-badge wf-badge-soft">@activity.SourceProperty</span>
                                        }
                                    </div>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(activity.Description))
                                {
                                    <div class="wf-node-description">@activity.Description</div>
                                }

                                @if (activity.Highlights.Any())
                                {
                                    <div class="wf-highlight-grid">
                                        @foreach (var item in activity.Highlights)
                                        {
                                            <div class="wf-highlight-item">
                                                <span class="wf-highlight-key">@item.Key:</span>
                                                <span class="wf-highlight-value">@item.Value</span>
                                            </div>
                                        }
                                    </div>
                                }

                                <div class="wf-node-footer">
                                    Profundidade estrutural: @activity.Depth
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="wf-section">
            <div class="wf-section-title">Conexões detectadas</div>

            @if (!Workflow.Connections.Any())
            {
                <div class="wf-empty">
                    Nenhuma conexão explícita foi encontrada. Se o JSON não trouxer as conexões, o viewer ainda mostra a estrutura das atividades.
                </div>
            }
            else
            {
                <div class="wf-connection-grid">
                    @foreach (var connection in Workflow.Connections)
                    {
                        <div class="wf-connection-card">
                            <div class="wf-connection-side">
                                <div class="wf-connection-label">Origem</div>
                                <div class="wf-connection-value">@connection.SourceLabel</div>
                                <div class="wf-connection-id">@connection.SourceId</div>
                            </div>

                            <div class="wf-connection-middle">
                                <div class="wf-connection-arrow">→</div>
                                @if (!string.IsNullOrWhiteSpace(connection.Outcome))
                                {
                                    <div class="wf-connection-outcome">@connection.Outcome</div>
                                }
                            </div>

                            <div class="wf-connection-side">
                                <div class="wf-connection-label">Destino</div>
                                <div class="wf-connection-value">@connection.TargetLabel</div>
                                <div class="wf-connection-id">@connection.TargetId</div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="wf-section">
            <div class="wf-section-title">JSON formatado</div>
            <details>
                <summary class="wf-json-summary">Abrir JSON completo</summary>
                <pre class="wf-json-box">@FormattedJson</pre>
            </details>
        </div>
    }
</div>

