@page "/workflow-viewer"
@rendermode InteractiveServer
@using System.Text.Json
@using System.Linq
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web

<PageTitle>Workflow Viewer</PageTitle>

<div class="wf-page">
    <div class="wf-header">
        <div>
            <h3>Workflow Graph Viewer</h3>
            <p class="wf-subtitle">
                Carregue um workflow JSON do Elsa para visualizar o fluxo como grafo e mover os nós com o mouse.
            </p>
        </div>
    </div>

    <div class="wf-toolbar">
        <InputFile OnChange="LoadWorkflowFile" accept=".json,application/json" class="form-control" />
    </div>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="wf-alert @(HasError ? "wf-alert-error" : "wf-alert-success")">
            @StatusMessage
        </div>
    }

    @if (Workflow is not null)
    {
        <div class="wf-summary-grid">
            <div class="wf-summary-card">
                <div class="wf-summary-label">Nome</div>
                <div class="wf-summary-value">@DisplayOrDash(Workflow.Name)</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">DefinitionId</div>
                <div class="wf-summary-value">@DisplayOrDash(Workflow.DefinitionId)</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">Id</div>
                <div class="wf-summary-value">@DisplayOrDash(Workflow.WorkflowId)</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">Tipo raiz</div>
                <div class="wf-summary-value">@DisplayOrDash(Workflow.RootType)</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">Nós</div>
                <div class="wf-summary-value">@GraphNodes.Count</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">Conexões</div>
                <div class="wf-summary-value">@GraphEdges.Count</div>
            </div>
        </div>

        <div class="wf-actions">
            <button class="btn btn-outline-primary btn-sm" @onclick="ResetLayout">Reorganizar layout</button>
        </div>

        @if (SelectedNode is not null)
        {
            <div class="wf-section">
                <div class="wf-section-title">Nó selecionado</div>

                <div class="wf-selected-card">
                    <div class="wf-selected-name">@SelectedNode.Label</div>
                    <div class="wf-selected-type">@SelectedNode.Type</div>
                    <div class="wf-selected-id">ID: @SelectedNode.Id</div>

                    @if (SelectedNode.Highlights.Any())
                    {
                        <div class="wf-selected-highlights">
                            @foreach (var item in SelectedNode.Highlights)
                            {
                                <div class="wf-selected-highlight">
                                    <strong>@item.Key:</strong> @item.Value
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <div class="wf-section">
            <div class="wf-section-title">Grafo interativo</div>
            <div class="wf-flow-note">
                Clique em um nó para selecionar. Segure o botão esquerdo do mouse sobre ele para mover.
            </div>

            <div class="graph-viewport">
                <div class="graph-canvas"
                     style="@($"width:{CanvasWidth}px;height:{CanvasHeight}px;")"
                     @onmousemove="OnCanvasMouseMove"
                     @onmouseup="OnCanvasMouseUp"
                     @onmouseleave="OnCanvasMouseUp">

                    <svg class="graph-svg" width="@CanvasWidth" height="@CanvasHeight">
                        <defs>
                            <marker id="arrowhead" markerWidth="10" markerHeight="7"
                                    refX="9" refY="3.5" orient="auto">
                                <polygon points="0 0, 10 3.5, 0 7" fill="#64748b" />
                            </marker>
                        </defs>

                        @foreach (var edge in GraphEdges)
                        {
                            var source = FindNode(edge.SourceId);
                            var target = FindNode(edge.TargetId);

                            if (source is null || target is null)
                                continue;

                            var x1 = source.X + NodeWidth;
                            var y1 = source.Y + (NodeHeight / 2.0);
                            var x2 = target.X;
                            var y2 = target.Y + (NodeHeight / 2.0);
                            var labelX = (x1 + x2) / 2.0;
                            var labelY = ((y1 + y2) / 2.0) - 8.0;

                            <line x1="@x1" y1="@y1" x2="@x2" y2="@y2"
                                  stroke="#94a3b8" stroke-width="2.5"
                                  marker-end="url(#arrowhead)" />                                                              
                        }
                    </svg>

                    @foreach (var edge in GraphEdges)
                    {
                        var source = FindNode(edge.SourceId);
                        var target = FindNode(edge.TargetId);

                        if (source is null || target is null || string.IsNullOrWhiteSpace(edge.Outcome))
                            continue;

                        var x1 = source.X + NodeWidth;
                        var y1 = source.Y + (NodeHeight / 2.0);
                        var x2 = target.X;
                        var y2 = target.Y + (NodeHeight / 2.0);

                        var labelX = ((x1 + x2) / 2.0) - 40.0;
                        var labelY = ((y1 + y2) / 2.0) - 12.0;

                        <div class="graph-edge-label"
                             style="@($"left:{labelX}px; top:{labelY}px;")">
                            @edge.Outcome
                        </div>
                    }

                    @foreach (var node in GraphNodes)
                    {
                        <div class="graph-node @GetNodeCssClass(node) @(SelectedNodeId == node.Id ? "selected" : "") @(_draggingNodeId == node.Id ? "dragging" : "")"
                             style="@NodeStyle(node)"
                             @onclick="() => SelectNode(node)"
                             @onmousedown="(e) => StartDrag(node, e)"
                             @onmousedown:preventDefault="true">

                            <div class="graph-node-title">@node.Label</div>
                            <div class="graph-node-type">@node.Type</div>
                            <div class="graph-node-id">@node.Id</div>

                            @if (node.Highlights.Any())
                            {
                                <div class="graph-node-highlights">
                                    @foreach (var item in node.Highlights.Take(3))
                                    {
                                        <div class="graph-node-highlight">
                                            <span class="graph-node-highlight-key">@item.Key:</span>
                                            <span class="graph-node-highlight-value">@item.Value</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="wf-section">
            <div class="wf-section-title">JSON formatado</div>
            <details>
                <summary class="wf-json-summary">Abrir JSON completo</summary>
                <pre class="wf-json-box">@FormattedJson</pre>
            </details>
        </div>
    }
</div>


