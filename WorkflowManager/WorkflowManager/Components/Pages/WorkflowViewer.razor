@page "/workflow-viewer"
@rendermode InteractiveServer
@using System.Text.Json
@using System.Linq
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web

<PageTitle>Workflow Viewer</PageTitle>

<div class="wf-page">
    <div class="wf-header">
        <div>
            <h3>Workflow Graph Viewer</h3>
            <p class="wf-subtitle">
                Carregue um workflow JSON do Elsa para visualizar o fluxo como grafo e mover os nós com o mouse.
            </p>
        </div>
    </div>

    <div class="wf-toolbar">
        <InputFile OnChange="LoadWorkflowFile" accept=".json,application/json" class="form-control" />
    </div>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="wf-alert @(HasError ? "wf-alert-error" : "wf-alert-success")">
            @StatusMessage
        </div>
    }

    @if (Workflow is not null)
    {
        <div class="wf-summary-grid">
            <div class="wf-summary-card">
                <div class="wf-summary-label">Nome</div>
                <div class="wf-summary-value">@DisplayOrDash(Workflow.Name)</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">DefinitionId</div>
                <div class="wf-summary-value">@DisplayOrDash(Workflow.DefinitionId)</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">Id</div>
                <div class="wf-summary-value">@DisplayOrDash(Workflow.WorkflowId)</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">Tipo raiz</div>
                <div class="wf-summary-value">@DisplayOrDash(Workflow.RootType)</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">Nós</div>
                <div class="wf-summary-value">@GraphNodes.Count</div>
            </div>

            <div class="wf-summary-card">
                <div class="wf-summary-label">Conexões</div>
                <div class="wf-summary-value">@GraphEdges.Count</div>
            </div>
        </div>

        <div class="wf-actions">
            <button class="btn btn-outline-primary btn-sm" @onclick="ResetLayout">Reorganizar layout</button>
        </div>

        @if (SelectedNode is not null)
        {
            <div class="wf-section">
                <div class="wf-section-title">Nó selecionado</div>

                <div class="wf-selected-card">
                    <div class="wf-selected-name">@SelectedNode.Label</div>
                    <div class="wf-selected-type">@SelectedNode.Type</div>
                    <div class="wf-selected-id">ID: @SelectedNode.Id</div>

                    @if (SelectedNode.Highlights.Any())
                    {
                        <div class="wf-selected-highlights">
                            @foreach (var item in SelectedNode.Highlights)
                            {
                                <div class="wf-selected-highlight">
                                    <strong>@item.Key:</strong> @item.Value
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <div class="wf-section">
            <div class="wf-section-title">Grafo interativo</div>
            <div class="wf-flow-note">
                Clique em um nó para selecionar. Segure o botão esquerdo do mouse sobre ele para mover.
            </div>

            <div class="graph-viewport">
                <div class="graph-canvas"
                     style="@($"width:{CanvasWidth}px;height:{CanvasHeight}px;")"
                     @onmousemove="OnCanvasMouseMove"
                     @onmouseup="OnCanvasMouseUp"
                     @onmouseleave="OnCanvasMouseUp">

                    <svg class="graph-svg" width="@CanvasWidth" height="@CanvasHeight">
                        <defs>
                            <marker id="arrowhead" markerWidth="10" markerHeight="7"
                                    refX="9" refY="3.5" orient="auto">
                                <polygon points="0 0, 10 3.5, 0 7" fill="#64748b" />
                            </marker>
                        </defs>

                        @foreach (var edge in GraphEdges)
                        {
                            var source = FindNode(edge.SourceId);
                            var target = FindNode(edge.TargetId);

                            if (source is null || target is null)
                                continue;

                            var x1 = source.X + NodeWidth;
                            var y1 = source.Y + (NodeHeight / 2.0);
                            var x2 = target.X;
                            var y2 = target.Y + (NodeHeight / 2.0);
                            var labelX = (x1 + x2) / 2.0;
                            var labelY = ((y1 + y2) / 2.0) - 8.0;

                            <line x1="@x1" y1="@y1" x2="@x2" y2="@y2"
                                  stroke="#94a3b8" stroke-width="2.5"
                                  marker-end="url(#arrowhead)" />                                                              
                        }
                    </svg>

                    @foreach (var edge in GraphEdges)
                    {
                        var source = FindNode(edge.SourceId);
                        var target = FindNode(edge.TargetId);

                        if (source is null || target is null || string.IsNullOrWhiteSpace(edge.Outcome))
                            continue;

                        var x1 = source.X + NodeWidth;
                        var y1 = source.Y + (NodeHeight / 2.0);
                        var x2 = target.X;
                        var y2 = target.Y + (NodeHeight / 2.0);

                        var labelX = ((x1 + x2) / 2.0) - 40.0;
                        var labelY = ((y1 + y2) / 2.0) - 12.0;

                        <div class="graph-edge-label"
                             style="@($"left:{labelX}px; top:{labelY}px;")">
                            @edge.Outcome
                        </div>
                    }

                    @foreach (var node in GraphNodes)
                    {
                        <div class="graph-node @GetNodeCssClass(node) @(SelectedNodeId == node.Id ? "selected" : "") @(_draggingNodeId == node.Id ? "dragging" : "")"
                             style="@NodeStyle(node)"
                             @onclick="() => SelectNode(node)"
                             @onmousedown="(e) => StartDrag(node, e)"
                             @onmousedown:preventDefault="true">

                            <div class="graph-node-title">@node.Label</div>
                            <div class="graph-node-type">@node.Type</div>
                            <div class="graph-node-id">@node.Id</div>

                            @if (node.Highlights.Any())
                            {
                                <div class="graph-node-highlights">
                                    @foreach (var item in node.Highlights.Take(3))
                                    {
                                        <div class="graph-node-highlight">
                                            <span class="graph-node-highlight-key">@item.Key:</span>
                                            <span class="graph-node-highlight-value">@item.Value</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="wf-section">
            <div class="wf-section-title">JSON formatado</div>
            <details>
                <summary class="wf-json-summary">Abrir JSON completo</summary>
                <pre class="wf-json-box">@FormattedJson</pre>
            </details>
        </div>
    }
</div>

<style>
    .wf-page {
        max-width: 1500px;
        margin: 0 auto;
        padding: 24px;
    }

    .wf-header {
        margin-bottom: 18px;
    }

    .wf-subtitle {
        color: #64748b;
        margin-top: 6px;
    }

    .wf-toolbar {
        margin-bottom: 16px;
    }

    .wf-alert {
        padding: 12px 14px;
        border-radius: 12px;
        margin-bottom: 18px;
        font-weight: 600;
    }

    .wf-alert-success {
        background: #ecfdf5;
        color: #166534;
        border: 1px solid #bbf7d0;
    }

    .wf-alert-error {
        background: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .wf-summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 14px;
        margin-bottom: 18px;
    }

    .wf-summary-card,
    .wf-section,
    .wf-selected-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.05);
    }

    .wf-summary-card {
        padding: 16px;
    }

    .wf-summary-label {
        font-size: 0.85rem;
        color: #64748b;
        margin-bottom: 6px;
    }

    .wf-summary-value {
        font-size: 1.05rem;
        font-weight: 700;
        word-break: break-word;
    }

    .wf-actions {
        margin-bottom: 18px;
    }

    .wf-section {
        padding: 18px;
        margin-bottom: 20px;
    }

    .wf-section-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 12px;
    }

    .wf-flow-note {
        color: #64748b;
        margin-bottom: 14px;
    }

    .wf-selected-card {
        padding: 16px;
        border-left: 6px solid #2563eb;
    }

    .wf-selected-name {
        font-size: 1.1rem;
        font-weight: 700;
    }

    .wf-selected-type {
        color: #64748b;
        margin-top: 4px;
    }

    .wf-selected-id {
        color: #475569;
        margin-top: 6px;
        font-size: 0.9rem;
        word-break: break-word;
    }

    .wf-selected-highlights {
        margin-top: 12px;
        display: grid;
        gap: 8px;
    }

    .wf-selected-highlight {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 12px;
        word-break: break-word;
    }

    .graph-viewport {
        overflow: auto;
        border: 1px solid #cbd5e1;
        border-radius: 18px;
        background: linear-gradient(180deg, #f8fafc, #eef2ff);
        padding: 14px;
    }

    .graph-canvas {
        position: relative;
        min-width: 1000px;
        min-height: 700px;
        background-image:
            linear-gradient(to right, rgba(148, 163, 184, 0.12) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(148, 163, 184, 0.12) 1px, transparent 1px);
        background-size: 24px 24px;
        border-radius: 16px;
    }

    .graph-svg {
        position: absolute;
        left: 0;
        top: 0;
        pointer-events: none;
        overflow: visible;
    }

    .graph-node {
        position: absolute;
        width: 240px;
        min-height: 140px;
        padding: 14px;
        border-radius: 16px;
        background: #ffffff;
        border: 2px solid #cbd5e1;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
        cursor: grab;
        user-select: none;
        transition: box-shadow 0.15s ease, transform 0.15s ease;
    }

    .graph-node:hover {
        box-shadow: 0 16px 28px rgba(15, 23, 42, 0.12);
        transform: translateY(-1px);
    }

    .graph-node.dragging {
        cursor: grabbing;
        box-shadow: 0 18px 36px rgba(37, 99, 235, 0.20);
        z-index: 50;
    }

    .graph-node.selected {
        border-color: #2563eb;
        box-shadow: 0 18px 36px rgba(37, 99, 235, 0.18);
    }

    .graph-node-root {
        border-left: 8px solid #0f766e;
        background: linear-gradient(135deg, #ecfeff, #ffffff);
    }

    .graph-node-control {
        border-left: 8px solid #7c3aed;
    }

    .graph-node-http {
        border-left: 8px solid #0891b2;
    }

    .graph-node-blocking {
        border-left: 8px solid #ea580c;
    }

    .graph-node-data {
        border-left: 8px solid #2563eb;
    }

    .graph-node-generic {
        border-left: 8px solid #475569;
    }

    .graph-node-title {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 4px;
        line-height: 1.2;
    }

    .graph-node-type {
        color: #64748b;
        font-size: 0.92rem;
        margin-bottom: 6px;
    }

    .graph-node-id {
        color: #94a3b8;
        font-size: 0.78rem;
        margin-bottom: 10px;
        word-break: break-word;
    }

    .graph-node-highlights {
        display: grid;
        gap: 6px;
    }

    .graph-node-highlight {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 6px 8px;
        font-size: 0.82rem;
        line-height: 1.25;
        word-break: break-word;
    }

    .graph-node-highlight-key {
        font-weight: 700;
        color: #334155;
        margin-right: 4px;
    }

    .graph-node-highlight-value {
        color: #475569;
    }

    .wf-json-summary {
        cursor: pointer;
        font-weight: 700;
        color: #334155;
    }

    .wf-json-box {
        margin-top: 12px;
        background: #0f172a;
        color: #e2e8f0;
        padding: 16px;
        border-radius: 14px;
        overflow: auto;
        max-height: 600px;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .graph-edge-label {
        position: absolute;
        min-width: 80px;
        max-width: 140px;
        padding: 4px 10px;
        border-radius: 999px;
        background: #ffffff;
        border: 1px solid #cbd5e1;
        color: #7c3aed;
        font-size: 11px;
        font-weight: 700;
        text-align: center;
        pointer-events: none;
        transform: translate(-50%, -50%);
        box-shadow: 0 4px 10px rgba(15, 23, 42, 0.08);
        z-index: 2;
    }
</style>

